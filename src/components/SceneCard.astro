---
interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
  articleCount: number;
}

const { icon, title, description, href, articleCount } = Astro.props;
const isImage = icon.startsWith('/');
---

<a
  href={href}
  class="group block rounded-xl bg-surface-light border border-surface-lighter hover:border-brand/40 transition-all duration-200 overflow-hidden"
>
  <div class="p-5">
    {isImage ? (
      <img src={icon} alt="" class="w-8 h-8 mb-3 object-contain" />
    ) : (
      <div class="text-2xl mb-3">{icon}</div>
    )}
    <h3 class="text-base font-bold mb-1.5 group-hover:text-brand-light transition-colors">
      {title}
    </h3>
    <p class="text-text-secondary text-sm mb-3 leading-relaxed">
      {description}
    </p>
    <span class="text-text-muted text-xs font-medium">
      {articleCount} 篇教學 →
    </span>
  </div>
</a>
