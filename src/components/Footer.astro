---
import type { Locale } from '../i18n/ui';

interface Props {
  lang?: Locale;
}

const { lang = 'zh-tw' } = Astro.props;
const year = new Date().getFullYear();
const isEn = lang === 'en';
---

<footer class="border-t border-surface-lighter">
  <div class="max-w-[900px] mx-auto px-6 py-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <img src="/icons/duck-happy.png" alt="藍鴨" class="duck-icon" style="width:24px;height:24px;object-fit:contain" />
        <span class="text-sm text-text-secondary">
          {isEn ? 'LaunchDock — Get your hands dirty, but not alone' : '藍鴨 LaunchDock — 弄髒雙手，但不孤單'}
        </span>
      </div>
      <div class="flex items-center gap-4">
        <a
          href="https://lab.launchdock.app"
          target="_blank"
          rel="noopener"
          class="text-text-muted hover:text-[#f59e0b] transition-colors text-sm"
        >
          🧪 {isEn ? 'Lab' : '實驗室'}
        </a>
        <a
          href="https://masters.launchdock.app"
          target="_blank"
          rel="noopener"
          class="text-text-muted hover:text-[#2f8f9d] transition-colors text-sm"
        >
          🎓 {isEn ? 'Masters' : '大師團'}
        </a>
        <a
          href="https://github.com/589411/launchdock"
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-muted hover:text-accent2 transition-colors text-sm"
        >
          GitHub
        </a>
        <a
          href={isEn ? '/en/#discussion' : '/#discussion'}
          class="text-text-muted hover:text-accent2 transition-colors text-sm"
        >
          {isEn ? 'Discuss' : '討論區'}
        </a>
      </div>
    </div>
    <p class="text-center text-text-muted text-xs mt-4">
      &copy; {year} 藍鴨 LaunchDock. Built with Astro.
    </p>
    <p class="text-center text-text-muted text-xs mt-2 opacity-70">
      {isEn
        ? 'An independent OpenClaw open-source community tutorial site.'
        : '本站為 OpenClaw 開源專案教學社群，與其他同名軟體無關。'}
    </p>
  </div>
</footer>
