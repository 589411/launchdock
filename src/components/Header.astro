---
import SearchTrigger from './SearchTrigger.tsx';
import ThemeToggle from './ThemeToggle.astro';
import AuthButton from './AuthButton.tsx';
import { useTranslations, getAlternatePath } from '../i18n/utils';
import { languages, type Locale } from '../i18n/ui';

interface Props {
  lang?: Locale;
}

const { lang = 'zh-tw' } = Astro.props;
const t = useTranslations(lang);
const otherLang = lang === 'zh-tw' ? 'en' : 'zh-tw';
const alternatePath = getAlternatePath(Astro.url, otherLang);

const navItems = [
  { label: t('nav.home'), href: lang === 'en' ? '/en/' : '/' },
  { label: t('nav.articles'), href: lang === 'en' ? '/en/articles/' : '/articles/' },
  { label: t('nav.quiz'), href: lang === 'en' ? '/en/quiz/' : '/quiz/' },
  { label: t('nav.events'), href: lang === 'en' ? '/en/events/' : '/events/' },
  { label: t('nav.about'), href: lang === 'en' ? '/en/about/' : '/about/' },
];
---

<header class="sticky top-0 z-50 bg-surface/90 backdrop-blur-md border-b border-surface-lighter shadow-sm">
  <nav class="max-w-[900px] mx-auto px-6 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <img src="/icons/duck-rocket.png" alt="" class="duck-icon" style="width:24px;height:24px;object-fit:contain" />
      <span class="text-lg font-bold text-text-primary group-hover:text-brand-light transition-colors tracking-tight">
        藍鴨 LaunchDock
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-text-secondary hover:text-text-primary transition-colors text-sm font-medium whitespace-nowrap"
        >
          {item.label}
        </a>
      ))}
      <a
        href={lang === 'en' ? '/en/#discussion' : '/#discussion'}
        class="text-text-secondary hover:text-text-primary transition-colors text-sm font-medium flex items-center gap-1 whitespace-nowrap"
      >
        💬 {t('nav.discussion')}
      </a>
      <!-- Tools dropdown (Lab / Masters) — pure-CSS hover -->
      <div class="relative group">
        <button
          class="text-text-secondary group-hover:text-text-primary transition-colors text-sm font-medium flex items-center gap-1 whitespace-nowrap"
          aria-haspopup="true"
        >
          🧰 {t('nav.tools')}
          <span class="text-[10px] opacity-70">▾</span>
        </button>
        <div class="absolute right-0 top-full pt-2 w-64 opacity-0 invisible group-hover:opacity-100 group-hover:visible focus-within:opacity-100 focus-within:visible transition-all duration-150 z-50">
          <div class="rounded-xl bg-surface border border-surface-lighter shadow-lg overflow-hidden py-1">
            <a href="https://lab.launchdock.app" target="_blank" rel="noopener" class="block px-4 py-2.5 hover:bg-surface-light transition-colors">
              <span class="text-sm font-semibold text-text-primary">🧪 {t('nav.tools.lab')}</span>
              <span class="block text-xs text-text-muted mt-0.5">lab.launchdock.app ↗</span>
            </a>
            <a href="https://masters.launchdock.app" target="_blank" rel="noopener" class="block px-4 py-2.5 hover:bg-surface-light transition-colors">
              <span class="text-sm font-semibold text-text-primary">🎓 {t('nav.tools.masters')}</span>
              <span class="block text-xs text-text-muted mt-0.5">masters.launchdock.app ↗</span>
            </a>
          </div>
        </div>
      </div>
      <SearchTrigger client:load />
      <!-- Language switcher -->
      <a
        href={alternatePath}
        class="text-xs font-semibold px-2 py-1 rounded-md border border-surface-lighter text-text-muted hover:text-text-primary hover:border-accent2 transition-colors"
        title={languages[otherLang]}
      >
        {languages[otherLang]}
      </a>
      <ThemeToggle />
      <AuthButton client:load />
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-text-secondary hover:text-text-primary"
      aria-label="開啟選單"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-surface-lighter bg-surface">
    <div class="px-4 py-4 space-y-3">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block text-text-secondary hover:text-text-primary transition-colors text-sm font-medium py-2"
        >
          {item.label}
        </a>
      ))}
      <a
        href={lang === 'en' ? '/en/#discussion' : '/#discussion'}
        class="block text-text-secondary hover:text-text-primary transition-colors text-sm font-medium py-2"
      >
        💬 {t('nav.discussion')}
      </a>
      <!-- Tools (Lab / Masters) — mobile -->
      <div class="pt-2 mt-1 border-t border-surface-lighter">
        <span class="block text-xs font-semibold text-text-muted uppercase tracking-wide py-1">🧰 {t('nav.tools')}</span>
        <a href="https://lab.launchdock.app" target="_blank" rel="noopener" class="block text-text-secondary hover:text-text-primary transition-colors text-sm font-medium py-2">
          🧪 {t('nav.tools.lab')} ↗
        </a>
        <a href="https://masters.launchdock.app" target="_blank" rel="noopener" class="block text-text-secondary hover:text-text-primary transition-colors text-sm font-medium py-2">
          🎓 {t('nav.tools.masters')} ↗
        </a>
      </div>
      <div class="py-2 flex items-center gap-3">
        <SearchTrigger client:load />
        <!-- Language switcher (mobile) -->
        <a
          href={alternatePath}
          class="text-xs font-semibold px-2 py-1 rounded-md border border-surface-lighter text-text-muted hover:text-text-primary transition-colors"
        >
          {languages[otherLang]}
        </a>
        <ThemeToggle />
        <AuthButton client:load />
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
