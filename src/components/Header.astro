---
import SearchTrigger from './SearchTrigger.tsx';
import ThemeToggle from './ThemeToggle.astro';
import AuthButton from './AuthButton.tsx';
import { useTranslations, getAlternatePath } from '../i18n/utils';
import { languages, type Locale } from '../i18n/ui';

interface Props {
  lang?: Locale;
}

const { lang = 'zh-tw' } = Astro.props;
const t = useTranslations(lang);
const otherLang = lang === 'zh-tw' ? 'en' : 'zh-tw';
const alternatePath = getAlternatePath(Astro.url, otherLang);

const navItems = [
  { label: t('nav.home'), href: lang === 'en' ? '/en/' : '/' },
  { label: t('nav.articles'), href: lang === 'en' ? '/en/articles' : '/articles' },
  { label: t('nav.events'), href: lang === 'en' ? '/en/events' : '/events' },
  { label: t('nav.about'), href: lang === 'en' ? '/en/about' : '/about' },
];
---

<header class="sticky top-0 z-50 bg-surface/90 backdrop-blur-md border-b border-surface-lighter shadow-sm">
  <nav class="max-w-[900px] mx-auto px-6 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <img src="/icons/duck-rocket.png" alt="" class="duck-icon" style="width:24px;height:24px;object-fit:contain" />
      <span class="text-lg font-bold text-text-primary group-hover:text-brand-light transition-colors tracking-tight">
        藍鴨 LaunchDock
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-5">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-text-secondary hover:text-text-primary transition-colors text-sm font-medium"
        >
          {item.label}
        </a>
      ))}
      <a
        href={lang === 'en' ? '/en/#discussion' : '/#discussion'}
        class="text-text-secondary hover:text-text-primary transition-colors text-sm font-medium flex items-center gap-1"
      >
        💬 {t('nav.discussion')}
      </a>
      <SearchTrigger client:load />
      <!-- Language switcher -->
      <a
        href={alternatePath}
        class="text-xs font-semibold px-2 py-1 rounded-md border border-surface-lighter text-text-muted hover:text-text-primary hover:border-accent2 transition-colors"
        title={languages[otherLang]}
      >
        {languages[otherLang]}
      </a>
      <ThemeToggle />
      <AuthButton client:load />
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-text-secondary hover:text-text-primary"
      aria-label="開啟選單"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-surface-lighter bg-surface">
    <div class="px-4 py-4 space-y-3">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block text-text-secondary hover:text-text-primary transition-colors text-sm font-medium py-2"
        >
          {item.label}
        </a>
      ))}
      <a
        href={lang === 'en' ? '/en/#discussion' : '/#discussion'}
        class="block text-text-secondary hover:text-text-primary transition-colors text-sm font-medium py-2"
      >
        💬 {t('nav.discussion')}
      </a>
      <div class="py-2 flex items-center gap-3">
        <SearchTrigger client:load />
        <!-- Language switcher (mobile) -->
        <a
          href={alternatePath}
          class="text-xs font-semibold px-2 py-1 rounded-md border border-surface-lighter text-text-muted hover:text-text-primary transition-colors"
        >
          {languages[otherLang]}
        </a>
        <ThemeToggle />
        <AuthButton client:load />
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
