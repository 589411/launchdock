---
/**
 * LearningPath — 首頁入門路線區塊
 * 顯示 6 步主線學習路線，已有文章的步驟可連結，缺的步驟顯示「即將推出」
 */
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.archived);

// Build a map: pathStep → article
const stepArticleMap = new Map<number, typeof allArticles[0]>();
for (const article of allArticles) {
  if (article.data.pathStep) {
    stepArticleMap.set(article.data.pathStep, article);
  }
}

const steps = [
  { step: 1, icon: '/icons/duck-compass.png', title: '認識 OpenClaw', desc: '了解它能幫你做什麼', time: '5 分鐘' },
  { step: 2, icon: '/icons/al-models.png', title: '選擇你的 AI 大腦', desc: 'LLM 方案比較與推薦', time: '8 分鐘' },
  { step: 3, icon: '/icons/duck-key.png', title: '申請 API Key', desc: '拿到讓 AI 運作的鑰匙', time: '10 分鐘' },
  { step: 4, icon: '/icons/duck-laptop.png', title: '安裝 OpenClaw', desc: '選擇你的平台，開始安裝', time: '15 分鐘' },
  { step: 5, icon: '/icons/duck-rocket.png', title: '第一次啟動', desc: '設定 Key、聽到 AI 的第一句話', time: '10 分鐘' },
  { step: 6, icon: '/icons/duck-bolt.png', title: '第一個 Skill', desc: '完成你的第一個自動化任務', time: '10 分鐘' },
];
---

<section class="max-w-[900px] mx-auto px-6 py-16">
  <div class="text-center mb-10">
    <span class="text-sm font-semibold text-brand-light tracking-wide uppercase">新手入門路線</span>
    <h2 class="text-2xl md:text-3xl font-extrabold mt-2 tracking-tight">從零開始，6 步上手</h2>
    <p class="text-text-secondary mt-2 max-w-lg mx-auto">
      每一步都有可操作的產出，跟著走就對了。
    </p>
  </div>

  <!-- Progress line + steps -->
  <div class="learning-path-container">
    {steps.map((s, i) => {
      const article = stepArticleMap.get(s.step);
      const available = !!article;
      const href = available ? `/articles/${article.id}` : undefined;
      const isLast = i === steps.length - 1;

      return (
        <div class="learning-path-step">
          {/* Connector line (except last) */}
          {!isLast && (
            <div class={`learning-path-line ${available && stepArticleMap.has(s.step + 1) ? 'active' : ''}`} />
          )}

          {/* Step node */}
          {available ? (
            <a href={href} class="learning-path-node available group">
              <div class="learning-path-icon">{s.icon.startsWith('/') ? <img src={s.icon} alt="" class="duck-icon" style="width:28px;height:28px;object-fit:contain" /> : s.icon}</div>
              <div class="learning-path-number">{s.step}</div>
              <div class="learning-path-content">
                <h3 class="font-semibold group-hover:text-brand-light transition-colors">{s.title}</h3>
                <p class="text-text-muted text-sm">{s.desc}</p>
                <span class="text-xs text-text-muted mt-1 inline-block">⏱ {s.time}</span>
              </div>
              <span class="learning-path-arrow group-hover:text-brand-light transition-colors">→</span>
            </a>
          ) : (
            <div class="learning-path-node upcoming">
              <div class="learning-path-icon dimmed">{s.icon.startsWith('/') ? <img src={s.icon} alt="" class="duck-icon" style="width:28px;height:28px;object-fit:contain;filter:grayscale(0.8)" /> : s.icon}</div>
              <div class="learning-path-number">{s.step}</div>
              <div class="learning-path-content">
                <h3 class="font-semibold text-text-muted">{s.title}</h3>
                <p class="text-text-muted text-sm">{s.desc}</p>
                <span class="text-xs text-brand-light/60 mt-1 inline-block">📝 即將推出</span>
              </div>
            </div>
          )}
        </div>
      );
    })}
  </div>
</section>
