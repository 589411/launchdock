---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EventList from '../../../components/EventList.tsx';
---

<BaseLayout title="Events" lang="en" description="Blue Duck Meetups — Learn, share, and solve problems with fellow AI enthusiasts.">
  <section class="max-w-[900px] mx-auto px-6 py-12">
    <div class="flex items-center gap-3 mb-2">
      <span class="text-2xl">🎟️</span>
      <h1 class="text-3xl font-extrabold">Events</h1>
    </div>
    <p class="text-text-secondary mb-10">
      Learning AI alone can be tough. Join our meetups to learn, share, and solve problems together.
    </p>

    <!-- Featured: Blue Duck Meetup (preview run uses a standalone page + external form) -->
    <a
      href="/meetup"
      class="block mb-10 p-6 rounded-2xl bg-gradient-to-br from-brand/15 to-surface-light border border-brand/40 hover:border-brand transition-all group"
    >
      <div class="flex items-center gap-2 mb-3">
        <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-brand text-white">Preview run</span>
        <span class="text-xs font-semibold text-brand-light tracking-wider">LIVE</span>
      </div>
      <h2 class="text-xl font-bold mb-1 group-hover:text-brand-light transition-colors">
        Blue Duck Meetup・Assemble! — Set up your first system prompt
      </h2>
      <p class="text-text-secondary text-sm mb-4">
        Stop re-explaining yourself to AI every time. In one evening, set up a system prompt once and never repeat it. Zero barrier — do it with the AI you already use. (Event held in Mandarin.)
      </p>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-1 text-sm text-text-secondary">
        <span>📅 Jul 29 (Wed)</span>
        <span>🕗 20:00–22:00</span>
        <span>📍 Online (Meet)</span>
        <span class="text-brand-light font-medium group-hover:underline">Details & sign up →</span>
      </div>
    </a>

    <EventList client:load />

    <!-- CTA -->
    <div class="mt-16 p-8 rounded-2xl bg-surface-light border border-surface-lighter text-center">
      <img src="/icons/duck-laptop.png" alt="Blue Duck" class="w-12 h-12 mx-auto mb-4 object-contain" />
      <h2 class="text-xl font-bold mb-2">Want to be notified about new events?</h2>
      <p class="text-text-secondary text-sm mb-4">
        Sign in with your Google account to become a member and get notified when new events are posted.
      </p>
      <div id="event-cta-auth"></div>
    </div>
  </section>
</BaseLayout>
