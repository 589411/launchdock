---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articlesEn', ({ data }) => !data.archived);
const hasArticles = allArticles.length > 0;
---

<BaseLayout
  title="Home"
  lang="en"
  description="LaunchDock — Step-by-step interactive AI tutorials. Learn how to run OpenClaw from scratch. The first English-language visual tutorial site for OpenClaw."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="max-w-[900px] mx-auto px-6 py-20 text-center">
      <div class="flex justify-center mb-6">
        <img src="/logo.png" alt="LaunchDock" class="w-40 md:w-56 h-auto" />
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 tracking-tight leading-tight">
        Learn OpenClaw,<br />hands-on.
      </h1>
      <p class="text-text-secondary text-lg md:text-xl max-w-[600px] mx-auto mb-8 leading-relaxed">
        LaunchDock provides step-by-step interactive tutorials to help you set up and run
        <strong class="text-text-primary">OpenClaw AI Agent</strong> from scratch.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="/en/articles"
          class="btn-primary px-6 py-3 rounded-xl font-semibold text-base"
        >
          Browse Tutorials →
        </a>
        <a
          href="/"
          class="px-6 py-3 rounded-xl font-semibold text-base border border-surface-lighter text-text-secondary hover:text-text-primary hover:border-accent2 transition-colors"
        >
          繁體中文版 →
        </a>
      </div>
    </div>
  </section>

  <!-- Content status -->
  <section class="max-w-[900px] mx-auto px-6 pb-20">
    {hasArticles ? (
      <div class="grid gap-4">
        {allArticles.slice(0, 6).map((article) => (
          <a
            href={`/en/articles/${article.id}`}
            class="block p-5 rounded-xl bg-surface-light hover:bg-surface-lighter border border-surface-lighter hover:border-brand/40 transition-all group"
          >
            <div class="flex items-center justify-between gap-4">
              <div>
                <h3 class="font-medium group-hover:text-brand-light transition-colors mb-1">
                  {article.data.title}
                </h3>
                <p class="text-text-muted text-sm">{article.data.description}</p>
              </div>
              <span class="text-text-muted group-hover:text-brand-light shrink-0 transition-colors">→</span>
            </div>
          </a>
        ))}
        {allArticles.length > 6 && (
          <a href="/en/articles" class="text-center text-brand-light hover:underline text-sm py-4">
            View all {allArticles.length} tutorials →
          </a>
        )}
      </div>
    ) : (
      <div class="text-center py-16 bg-surface-light rounded-2xl border border-surface-lighter">
        <img src="/icons/duck-rocket.png" alt="" class="duck-icon w-20 h-20 mx-auto mb-4 opacity-70" />
        <h2 class="text-xl font-bold mb-2">English tutorials coming soon!</h2>
        <p class="text-text-secondary text-sm mb-6 max-w-md mx-auto">
          We're actively working on English translations of our OpenClaw tutorial library.
          In the meantime, check out the Traditional Chinese version.
        </p>
        <div class="flex justify-center gap-3">
          <a
            href="/"
            class="px-5 py-2.5 rounded-xl bg-brand text-white font-semibold text-sm hover:bg-brand/90 transition-colors"
          >
            繁體中文教學 →
          </a>
          <a
            href="https://github.com/589411/launchdock"
            target="_blank"
            rel="noopener noreferrer"
            class="px-5 py-2.5 rounded-xl border border-surface-lighter text-text-secondary font-semibold text-sm hover:border-accent2 hover:text-text-primary transition-colors"
          >
            GitHub
          </a>
        </div>
      </div>
    )}
  </section>
</BaseLayout>
