---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventList from '../../components/EventList.tsx';
---

<BaseLayout title="活動" description="藍鴨小聚 — 和其他養蝦人一起學習、交流、解決問題。">
  <section class="max-w-[900px] mx-auto px-6 py-12">
    <div class="flex items-center gap-3 mb-2">
      <span class="text-2xl">🎟️</span>
      <h1 class="text-3xl font-extrabold">藍鴨活動</h1>
    </div>
    <p class="text-text-secondary mb-10">
      一個人養蝦太孤單？來參加藍鴨小聚，和其他養蝦人一起學習、交流、解決問題。
    </p>

    <!-- 精選：藍鴨小聚（試營運場走獨立頁 + 外部報名表單） -->
    <a
      href="/meetup"
      class="block mb-10 p-6 rounded-2xl bg-gradient-to-br from-brand/15 to-surface-light border border-brand/40 hover:border-brand transition-all group"
    >
      <div class="flex items-center gap-2 mb-3">
        <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-brand text-white">搶先試營運</span>
        <span class="text-xs font-semibold text-brand-light tracking-wider">LIVE</span>
      </div>
      <h2 class="text-xl font-bold mb-1 group-hover:text-brand-light transition-colors">
        藍鴨小聚・鴨聚 Assemble！— 設定你的第一個系統提示詞
      </h2>
      <p class="text-text-secondary text-sm mb-4">
        別再每次都跟 AI 重講一遍。這一晚，鴨編帶你設定一次系統提示詞，從此不用再重講。零門檻，打開你已經在用的 AI 就能做。
      </p>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-1 text-sm text-text-secondary">
        <span>📅 7/29（三）</span>
        <span>🕗 20:00–22:00</span>
        <span>📍 線上 Meet</span>
        <span class="text-brand-light font-medium group-hover:underline">看詳情・報名 →</span>
      </div>
    </a>

    <EventList client:load />

    <!-- CTA -->
    <div class="mt-16 p-8 rounded-2xl bg-surface-light border border-surface-lighter text-center">
      <img src="/icons/duck-laptop.png" alt="藍鴨" class="w-12 h-12 mx-auto mb-4 object-contain" />
      <h2 class="text-xl font-bold mb-2">想被通知新活動？</h2>
      <p class="text-text-secondary text-sm mb-4">
        用 Google 帳號登入即可成為會員，新活動上架時會自動通知你。
      </p>
      <div id="event-cta-auth"></div>
    </div>
  </section>
</BaseLayout>
