---
import BaseLayout from '../layouts/BaseLayout.astro';
import LearningPath from '../components/LearningPath.astro';
import SceneCard from '../components/SceneCard.astro';
import PopularArticlesHome from '../components/PopularArticlesHome.tsx';
import HomeDiscussion from '../components/HomeDiscussion.tsx';
import EventList from '../components/EventList.tsx';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.archived);

// Group articles by scene
const sceneMap = new Map<string, typeof allArticles>();
for (const article of allArticles) {
  const scene = article.data.scene;
  if (!sceneMap.has(scene)) sceneMap.set(scene, []);
  sceneMap.get(scene)!.push(article);
}

// New top-level sections (replaces old 8-scene flat grid)
const sections = [
  { key: '新手養蝦', icon: '🦐', description: '從零開始安裝 OpenClaw 並跑起來', anchor: '#learning-path' },
  { key: '基礎知識', icon: '📘', description: 'LLM、API Key、Token、CLI 等核心概念', scenes: ['認識 OpenClaw', '環境準備'] },
  { key: '應用實戰', icon: '⚡', description: 'Skill、整合外部服務、自動化工作流', scenes: ['基礎使用', '整合與自動化'] },
  { key: '龍蝦架構', icon: '🏗️', description: 'Agent、Skill、Soul、MCP、Tools 深度拆解', scenes: ['核心功能'] },
  { key: '知識進階', icon: '📚', description: 'PKM、Prompt 工程、RAG、推理技術', scenes: ['知識與進階'] },
  { key: '鴨編的碎碎念', icon: '/images/dock_head_s.png', description: 'AI 趨勢觀察、產業洞察與鴨編的真心話', scenes: ['鴨編的碎碎念'] },
];

// Count articles for each section
function countArticles(sectionScenes?: string[]) {
  if (!sectionScenes) return 0;
  return sectionScenes.reduce((sum, s) => sum + (sceneMap.get(s)?.length || 0), 0);
}

// Get latest articles
const latestArticles = [...allArticles].sort((a, b) =>
  new Date(b.data.createdAt).getTime() - new Date(a.data.createdAt).getTime()
).slice(0, 5);

// Prepare lightweight article metadata for PopularArticlesHome
const articlesMeta = allArticles.map(a => ({
  slug: a.id,
  title: a.data.title,
  description: a.data.description,
  scene: a.data.scene,
  difficulty: a.data.difficulty,
  tags: a.data.tags,
}));
---

<BaseLayout
  title="首頁"
  description="藍鴨 LaunchDock 是手把手的互動式 AI 教學空間。針對影片太快、文件看不懂、實作卡關等痛點，用可跟做的路線帶你把 OpenClaw 跑起來。全台首創 OpenClaw 繁體中文視覺化教學站。"
>
  <!-- Hero Section -->
  <section class="hero-section relative overflow-hidden">
    <div class="max-w-[900px] mx-auto px-6 text-center">
      <div class="flex justify-center mb-6">
        <img src="/logo.png" alt="藍鴨 LaunchDock" class="w-40 md:w-56 h-auto" />
      </div>
      <h1 class="text-3xl md:text-[2.4rem] font-extrabold mb-4 leading-tight tracking-tight">
        藍鴨 LaunchDock｜龍蝦<span class="highlight">OpenClaw</span> 繁體中文自動化教學
      </h1>
      <p class="text-base text-[#94a3b8] mb-3">弄髒雙手，但不用弄髒全身</p>
      <p class="text-lg text-[#cbd5e1] max-w-2xl mx-auto mb-8 leading-relaxed">
        AI 圈的人都說「just do it」——<br />
        但對非技術背景的你來說，跟著做往往不只是弄髒雙手，而是弄髒全身。<br />
        藍鴨 LaunchDock 讓你安心動手——每一步都有截圖、每個卡點都能回報、每個問題都有人接。
      </p>
      <div class="flex flex-wrap gap-2.5 justify-center mb-8">
        <span class="badge">✅ 繁體中文</span>
        <span class="badge">📸 每步截圖</span>
        <span class="badge">💬 即時問答</span>
        <span class="badge">🦆 藍鴨陪你</span>
      </div>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#learning-path"
          class="px-8 py-3 bg-brand hover:bg-brand-dark text-white rounded-lg font-medium transition-colors"
        >
          🚀 新手養蝦路線
        </a>
        <a
          href="/articles"
          class="px-8 py-3 border border-white/25 hover:border-white/50 text-white/85 hover:text-white rounded-lg font-medium transition-all"
        >
          📚 瀏覽所有文章
        </a>
      </div>
    </div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-[#e94560]/10 rounded-full blur-3xl -z-10"></div>
  </section>

  <!-- Pain Point Section -->
  <section class="max-w-[900px] mx-auto px-6 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <div class="p-6 rounded-xl bg-surface-light border border-surface-lighter hover:border-brand/30 transition-all">
        <span class="text-2xl mb-3 block">🤯</span>
        <h3 class="font-semibold mb-2">跟著做，卻不知道哪裡做錯</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          教學說「很簡單」，但你卡了兩小時。不是你笨——是中間少了十個沒人講的步驟。
        </p>
      </div>
      <div class="p-6 rounded-xl bg-surface-light border border-surface-lighter hover:border-brand/30 transition-all">
        <span class="text-2xl mb-3 block">😰</span>
        <h3 class="font-semibold mb-2">出了錯，不知道問誰</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          Google 到的答案全是英文，而且假設你已經懂。錯誤訊息貼到 ChatGPT，它叫你做更多看不懂的事。
        </p>
      </div>
      <div class="p-6 rounded-xl bg-surface-light border border-surface-lighter hover:border-brand/30 transition-all">
        <span class="text-2xl mb-3 block">🫣</span>
        <h3 class="font-semibold mb-2">怕弄壞東西，不敢動手</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          不確定這步會不會搞爛電腦、會不會被扣錢、會不會刪到重要東西。所以你選擇繼續觀望。
        </p>
      </div>
    </div>
  </section>

  <!-- Promise Section -->
  <section class="max-w-[700px] mx-auto px-6 py-8 text-center">
    <h2 class="text-2xl font-bold mb-4">所以我們這樣做</h2>
    <p class="text-text-secondary text-lg leading-relaxed">
      每篇教學都有截圖、每個步驟都能回報卡關、每一個困惑都有人回答。<br />
      你只要願意動手，我們負責讓你不弄髒全身。
    </p>
  </section>

  <!-- 🔥 Popular Articles (prominent position) -->
  <section class="max-w-[900px] mx-auto px-6 py-14">
    <div class="flex items-center gap-3 mb-2">
      <span class="text-2xl">🔥</span>
      <h2 class="text-2xl font-bold">大家都在看</h2>
    </div>
    <p class="text-text-secondary mb-8">最多人閱讀的教學文章，跟著讀準沒錯。</p>
    <PopularArticlesHome client:load articles={articlesMeta} />
  </section>

  <!-- 🦐 Learning Path (Primary CTA) -->
  <div id="learning-path">
    <LearningPath />
  </div>

  <!-- Topic Sections (new structure) -->
  <section class="max-w-[900px] mx-auto px-6 py-14">
    <h2 class="text-2xl font-bold mb-2">從你想做的事開始弄髒雙手</h2>
    <p class="text-text-secondary mb-8">已經上手了？從你的問題出發，找到更多進階教學。</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {sections.map((section) => {
        const isAnchor = !!section.anchor;
        const articleCount = isAnchor ? 0 : countArticles(section.scenes);
        const href = isAnchor
          ? section.anchor!
          : `/articles?scene=${encodeURIComponent(section.scenes![0])}`;

        return (
          <SceneCard
            icon={section.icon}
            title={section.key}
            description={section.description}
            href={href}
            articleCount={articleCount}
          />
        );
      })}
    </div>
  </section>

  <!-- 🦆 藍鴨小聚 CTA -->
  <section class="max-w-[900px] mx-auto px-6 py-14">
    <div class="rounded-2xl overflow-hidden border border-surface-lighter bg-gradient-to-br from-surface-light to-[#16213e]">
      <div class="p-8 md:p-12 text-center">
        <img src="/images/dock_head_s.png" alt="藍鴨" class="w-16 h-16 mx-auto mb-4 object-contain" />
        <h2 class="text-2xl md:text-3xl font-extrabold mb-3 tracking-tight">藍鴨小聚</h2>
        <p class="text-text-secondary text-lg max-w-xl mx-auto mb-2">
          一個人養蝦太孤單？和其他養蝦人一起學習、交流、解決問題。
        </p>
        <p class="text-text-muted text-sm mb-8">
          線上聚會 → 主題工作坊 → 實體活動，一步一步來。
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-2xl mx-auto mb-10">
          <div class="p-4 rounded-xl bg-surface-light/50 border border-surface-lighter">
            <span class="text-xl block mb-2">💻</span>
            <h4 class="font-semibold text-sm mb-1">線上小聚</h4>
            <p class="text-text-muted text-xs">每月一次，免費參加</p>
          </div>
          <div class="p-4 rounded-xl bg-surface-light/50 border border-surface-lighter">
            <span class="text-xl block mb-2">🎓</span>
            <h4 class="font-semibold text-sm mb-1">主題課程</h4>
            <p class="text-text-muted text-xs">深入特定主題的付費課程</p>
          </div>
          <div class="p-4 rounded-xl bg-surface-light/50 border border-surface-lighter">
            <span class="text-xl block mb-2">🤝</span>
            <h4 class="font-semibold text-sm mb-1">實體工作坊</h4>
            <p class="text-text-muted text-xs">面對面手把手帶你做</p>
          </div>
        </div>

        <!-- Dynamic upcoming event -->
        <div class="max-w-md mx-auto mb-8">
          <EventList client:load compact={true} />
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/events"
            class="px-8 py-3 bg-brand hover:bg-brand-dark text-white rounded-lg font-medium transition-colors"
          >
            🎟️ 查看所有活動
          </a>
          <a
            href="#discussion"
            class="px-8 py-3 border border-white/25 hover:border-white/50 text-white/85 hover:text-white rounded-lg font-medium transition-all"
          >
            先看看大家在聊什麼
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  {latestArticles.length > 0 && (
    <section class="max-w-[900px] mx-auto px-6 py-14">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-2xl font-bold">最新教學</h2>
        <span class="text-xs text-text-muted">內容最後更新：{latestArticles[0].data.verifiedAt || latestArticles[0].data.createdAt}</span>
      </div>
      <p class="text-text-secondary mb-8">剛出爐的實戰筆記。</p>
      <div class="space-y-3">
        {latestArticles.map((article) => (
          <a
            href={`/articles/${article.id}`}
            class="block p-5 rounded-xl bg-surface-light hover:bg-surface-lighter border border-surface-lighter hover:border-brand/40 transition-all group"
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-xs px-2 py-1 rounded-full bg-brand/20 text-brand-light">
                    {article.data.scene}
                  </span>
                  <span class={`text-xs px-2 py-1 rounded-full ${
                    article.data.difficulty === '入門' ? 'bg-green-500/20 text-green-400' :
                    article.data.difficulty === '中級' ? 'bg-yellow-500/20 text-yellow-400' :
                    'bg-red-500/20 text-red-400'
                  }`}>
                    {article.data.difficulty}
                  </span>
                </div>
                <h3 class="font-semibold group-hover:text-brand-light transition-colors">
                  {article.data.title}
                </h3>
                <p class="text-text-secondary text-sm mt-1">{article.data.description}</p>
              </div>
              <span class="text-text-muted group-hover:text-brand-light transition-colors shrink-0">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Discussion Section -->
  <section id="discussion" class="max-w-[900px] mx-auto px-6 py-16">
    <HomeDiscussion client:load />
  </section>
</BaseLayout>


