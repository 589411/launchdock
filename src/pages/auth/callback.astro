---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="登入中..." description="正在完成 Google 登入">
  <div class="max-w-md mx-auto px-6 py-24 text-center">
    <div id="callback-loading">
      <span class="text-4xl block mb-4">🔑</span>
      <p class="text-lg text-text-secondary">正在完成登入...</p>
    </div>
    <div id="callback-error" class="hidden">
      <span class="text-4xl block mb-4">❌</span>
      <p class="text-lg text-text-primary font-semibold mb-2">登入失敗</p>
      <p id="error-message" class="text-text-secondary text-sm mb-6"></p>
      <a
        href="/"
        class="px-6 py-2.5 bg-brand hover:bg-brand-dark text-white rounded-lg font-medium transition-colors inline-block"
      >
        回到首頁
      </a>
    </div>
    <div id="callback-success" class="hidden">
      <span class="text-4xl block mb-4">✅</span>
      <p class="text-lg text-text-primary font-semibold mb-2">登入成功！</p>
      <p class="text-text-secondary text-sm">正在跳轉...</p>
    </div>
  </div>
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { isSupabaseConfigured } from '../../lib/supabase';

  async function handleCallback() {
    const loadingEl = document.getElementById('callback-loading');
    const errorEl = document.getElementById('callback-error');
    const successEl = document.getElementById('callback-success');
    const errorMsg = document.getElementById('error-message');

    function showError(msg: string) {
      loadingEl?.classList.add('hidden');
      errorEl?.classList.remove('hidden');
      if (errorMsg) errorMsg.textContent = msg;
    }

    function showSuccess() {
      loadingEl?.classList.add('hidden');
      successEl?.classList.remove('hidden');
      const returnTo = sessionStorage.getItem('auth-return-to') || '/';
      sessionStorage.removeItem('auth-return-to');
      setTimeout(() => { window.location.href = returnTo; }, 800);
    }

    if (!isSupabaseConfigured()) {
      showError('Supabase 尚未設定');
      return;
    }

    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    // Create a dedicated client WITH detectSessionInUrl enabled.
    // The main app client has it disabled to prevent double-parsing,
    // but on this callback page we NEED Supabase to auto-detect tokens.
    const callbackClient = createClient(supabaseUrl, supabaseKey, {
      auth: {
        autoRefreshToken: true,
        persistSession: true,
        detectSessionInUrl: true,
      },
    });

    try {
      // Wait for Supabase to auto-detect and set the session from URL
      // This handles both implicit (#access_token) and PKCE (?code=) flows
      const { data: { session }, error } = await callbackClient.auth.getSession();

      if (error) {
        showError(`登入錯誤：${error.message}`);
        return;
      }

      if (session) {
        showSuccess();
        return;
      }

      // Session not yet available — listen for auth state change
      let done = false;
      const { data: { subscription } } = callbackClient.auth.onAuthStateChange(
        (_event, s) => {
          if (done || !s) return;
          done = true;
          subscription.unsubscribe();
          showSuccess();
        }
      );

      // Timeout fallback
      setTimeout(() => {
        if (done) return;
        done = true;
        subscription.unsubscribe();
        showError('登入逾時，請重試。');
      }, 10000);
    } catch {
      showError('發生未預期的錯誤，請重試。');
    }
  }

  handleCallback();
</script>
