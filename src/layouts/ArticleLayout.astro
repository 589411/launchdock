---
import BaseLayout from './BaseLayout.astro';
import ArticleMeta from '../components/ArticleMeta.astro';
import ArticleProgressBar from '../components/ArticleProgressBar.astro';
import GifPlayer from '../components/GifPlayer.astro';
import EmotionFeedback from '../components/EmotionFeedback.tsx';
import SectionReactions from '../components/SectionReactions.tsx';
import ArticleQA from '../components/ArticleQA.tsx';
import RelatedArticles from '../components/RelatedArticles.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    scene: string;
    difficulty: '入門' | '中級' | '進階';
    createdAt: string;
    verifiedAt: string;
    archived?: boolean;
    archivedReason?: string;
    discussionUrl?: string;
    pathStep?: number;
    stuckOptions?: Record<string, string[]>;
    tags?: string[];
    prerequisites?: string[];
  };
}

const { frontmatter } = Astro.props;
const slug = Astro.url.pathname.replace(/^\/articles\//, '').replace(/\/$/, '');
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="max-w-3xl mx-auto px-4 py-8">
    <!-- Learning Path Progress Bar (only for path articles) -->
    {frontmatter.pathStep && (
      <ArticleProgressBar currentStep={frontmatter.pathStep} />
    )}

    <!-- Article Header -->
    <header class="mb-8">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-sm px-3 py-1 rounded-full bg-brand/20 text-brand-light">
          {frontmatter.scene}
        </span>
        <span class={`text-sm px-3 py-1 rounded-full ${
          frontmatter.difficulty === '入門' ? 'bg-green-500/20 text-green-400' :
          frontmatter.difficulty === '中級' ? 'bg-yellow-500/20 text-yellow-400' :
          'bg-red-500/20 text-red-400'
        }`}>
          {frontmatter.difficulty}
        </span>
      </div>

      <h1 class="text-3xl font-bold mb-4 leading-tight">
        {frontmatter.title}
      </h1>

      <p class="text-text-secondary text-lg mb-4">
        {frontmatter.description}
      </p>

      <ArticleMeta
        createdAt={frontmatter.createdAt}
        verifiedAt={frontmatter.verifiedAt}
        archived={frontmatter.archived}
        archivedReason={frontmatter.archivedReason}
      />

      {frontmatter.archived && (
        <div class="mt-4 p-4 rounded-lg bg-red-500/10 border border-red-500/30">
          <p class="text-red-400 text-sm">
            ⚠️ 此文章已封存：{frontmatter.archivedReason || '內容可能已過時'}
          </p>
        </div>
      )}

      <!-- Section reactions hint -->
      <div class="mt-4 px-3 py-2 rounded-lg bg-surface-light/50 text-xs text-text-muted flex items-center gap-2">
        <img src="/images/dock_head_s.png" alt="鴨編" width="20" height="20" style="vertical-align: middle;" />
        <span>
          卡住很正常——點段落旁的 <strong class="text-text-secondary">😵 卡關</strong> 讓我們知道，或直接往下滾到問答區發問。
          也可以用 <strong class="text-text-secondary">👍 看懂</strong> / <strong class="text-text-secondary">😢 看不懂</strong> 告訴我們哪裡寫得好、哪裡要改。
        </span>
      </div>
    </header>

    <!-- Article Content (with per-section reactions injected by SectionReactions) -->
    <div class="prose">
      <slot />
    </div>

    <!-- Section Reactions (injects emoji buttons next to each h2) -->
    <SectionReactions client:load slug={slug} stuckOptions={frontmatter.stuckOptions || {}} />

    <!-- GIF Play-once Controller -->
    <GifPlayer />

    <!-- Article-level Emotion Feedback -->
    <div class="mt-12 pt-8 border-t border-surface-lighter">
      <EmotionFeedback client:load slug={slug} />
    </div>

    <!-- Related Articles (auto-generated from concepts.yaml) -->
    <div class="mt-10">
      <RelatedArticles
        slug={slug}
        tags={frontmatter.tags || []}
        prerequisites={frontmatter.prerequisites || []}
        scene={frontmatter.scene}
      />
    </div>

    <!-- Q&A Section (replaces GitHub Discussions) -->
    <div class="mt-8 pt-8 border-t border-surface-lighter">
      <ArticleQA client:load slug={slug} />
    </div>
  </article>
</BaseLayout>
