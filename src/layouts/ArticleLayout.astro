---
import BaseLayout from './BaseLayout.astro';
import ArticleMeta from '../components/ArticleMeta.astro';
import ArticleProgressBar from '../components/ArticleProgressBar.astro';
import GifPlayer from '../components/GifPlayer.astro';
import EmotionFeedback from '../components/EmotionFeedback.tsx';
import SectionReactions from '../components/SectionReactions.tsx';
import ArticleQA from '../components/ArticleQA.tsx';
import RelatedArticles from '../components/RelatedArticles.astro';
import PageViewTracker from '../components/PageViewTracker.tsx';
import { sceneKeyToLabel, difficultyKeyToLabel, type Locale } from '../i18n/ui';
import { articlesPath } from '../i18n/utils';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    scene: string;
    difficulty: string;
    createdAt: string;
    verifiedAt: string;
    archived?: boolean;
    archivedReason?: string;
    discussionUrl?: string;
    pathStep?: number;
    stuckOptions?: Record<string, string[]>;
    tags?: string[];
    prerequisites?: string[];
  };
  lang?: Locale;
}

const { frontmatter, lang = 'zh-tw' } = Astro.props;

// Derive slug: strip locale prefix and /articles/ prefix
const rawPath = Astro.url.pathname;
const slug = rawPath
  .replace(/^\/en\/articles\//, '')
  .replace(/^\/articles\//, '')
  .replace(/\/$/, '');

// Locale-aware display labels
const sceneDisplay = sceneKeyToLabel[lang][frontmatter.scene] ?? frontmatter.scene;
const difficultyDisplay = difficultyKeyToLabel[lang][frontmatter.difficulty] ?? frontmatter.difficulty;
const difficultyIcon =
  ['入門', 'beginner'].includes(frontmatter.difficulty) ? '✅' :
  ['中級', 'intermediate'].includes(frontmatter.difficulty) ? '⚡' : '🔥';

const articlesBase = articlesPath(lang);
const homeHref = lang === 'en' ? '/en/' : '/';
const homeName = lang === 'en' ? 'LaunchDock' : '藍鴨 LaunchDock';
---

<BaseLayout title={frontmatter.title} description={frontmatter.description} lang={lang}>
  <PageViewTracker slug={slug} client:only="react" />
  <article class="max-w-[900px] mx-auto px-6 py-10">
    <!-- Branded Breadcrumb for SEO -->
    <nav class="text-xs text-text-muted mb-6" aria-label="breadcrumb">
      <a href={homeHref} class="hover:text-accent2 transition-colors">{homeName}</a>
      <span class="mx-1.5 opacity-50">/</span>
      <a href={`${articlesBase}?scene=${encodeURIComponent(frontmatter.scene)}`} class="hover:text-accent2 transition-colors">{sceneDisplay}</a>
      <span class="mx-1.5 opacity-50">/</span>
      <span class="text-text-secondary">{frontmatter.title}</span>
    </nav>

    <!-- Learning Path Progress Bar (only for path articles) -->
    {frontmatter.pathStep && (
      <ArticleProgressBar currentStep={frontmatter.pathStep} />
    )}

    <!-- Article Header (phase-card style) -->
    <header class="mb-10 rounded-xl bg-surface-light border border-surface-lighter overflow-hidden">
      <!-- Gradient header bar -->
      <div class="bg-gradient-to-r from-accent2 to-accent2-light px-6 py-4">
        <div class="flex flex-wrap items-center gap-2 mb-2">
          <span class="badge text-xs">
            {sceneDisplay}
          </span>
          <span class="badge text-xs">
            {difficultyIcon} {difficultyDisplay}
          </span>
        </div>
        <h1 class="text-2xl md:text-[1.8rem] font-extrabold text-white leading-tight tracking-tight">
          {frontmatter.title}
        </h1>
      </div>
      <!-- Body -->
      <div class="px-6 py-5">
        <p class="text-text-secondary text-base mb-4 leading-relaxed">
          {frontmatter.description}
        </p>

        <ArticleMeta
          createdAt={frontmatter.createdAt}
          verifiedAt={frontmatter.verifiedAt}
          archived={frontmatter.archived}
          archivedReason={frontmatter.archivedReason}
        />

        {frontmatter.archived && (
          <div class="mt-4 p-4 rounded-lg bg-red-500/10 border border-red-500/30">
            <p class="text-red-400 text-sm">
              ⚠️ 此文章已封存：{frontmatter.archivedReason || '內容可能已過時'}
            </p>
          </div>
        )}

        <!-- Section reactions hint -->
        <div class="mt-4 px-4 py-3 rounded-lg bg-surface/50 border border-surface-lighter text-xs text-text-muted flex items-center gap-2">
          <img src="/images/dock_head_s.png" alt="鴨編" width="20" height="20" style="vertical-align: middle;" />
          <span>
            卡住很正常——點段落旁的 <strong class="text-text-secondary">😵 卡關</strong> 讓我們知道，或直接往下滾到問答區發問。
            也可以用 <strong class="text-text-secondary">👍 看懂</strong> / <strong class="text-text-secondary">😢 看不懂</strong> 告訴我們哪裡寫得好、哪裡要改。
          </span>
        </div>
      </div>
    </header>

    <!-- Article Content (with per-section reactions injected by SectionReactions) -->
    <div class="prose">
      <slot />
    </div>

    <!-- Section Reactions (injects emoji buttons next to each h2) -->
    <SectionReactions client:load slug={slug} stuckOptions={frontmatter.stuckOptions || {}} />

    <!-- GIF Play-once Controller -->
    <GifPlayer />

    <!-- Article-level Emotion Feedback -->
    <div class="mt-12 pt-8 border-t border-surface-lighter">
      <EmotionFeedback client:load slug={slug} />
    </div>

    <!-- Related Articles (auto-generated from concepts.yaml) -->
    <div class="mt-10">
      <RelatedArticles
        slug={slug}
        tags={frontmatter.tags || []}
        prerequisites={frontmatter.prerequisites || []}
        scene={frontmatter.scene}
      />
    </div>

    <!-- Q&A Section (replaces GitHub Discussions) -->
    <div class="mt-8 pt-8 border-t border-surface-lighter">
      <ArticleQA client:load slug={slug} />
    </div>
  </article>
</BaseLayout>
